# =============================================================================
# .env.example — variables de entorno requeridas
# Copiar a .env y rellenar los valores reales (NUNCA commitear .env)
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=logistics_routes
POSTGRES_USER=logistics_user
POSTGRES_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false

# ── JWT ───────────────────────────────────────────────────────────────────────
# Genera con: openssl rand -base64 48
JWT_SECRET=CAMBIAR_POR_SECRET_LARGO_Y_ALEATORIO
JWT_EXPIRATION_MS=86400000

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-2

# ── SQS — nombres exactos de las colas creadas en la consola AWS ─────────────
SQS_SOLICITUDES_RUTA_QUEUE=logistics-solicitudes-ruta
SQS_EVENTOS_PAQUETE_QUEUE=logistics-eventos-paquete
SQS_CIERRE_RUTA_QUEUE=logistics-cierre-ruta

# ── S3 — nombre exacto del bucket creado en la consola AWS ───────────────────
S3_BUCKET_POD=logistics-pod-fotos
