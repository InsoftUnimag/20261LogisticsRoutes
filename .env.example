# Variables de entorno para desarrollo local
# Ejemplo

# ── PostgreSQL (Docker) ───────────────────────────────────────────────
POSTGRES_DB=logistics_routes_dev
POSTGRES_USER=logistics_user
POSTGRES_PASSWORD=logistics_dev_pwd

# ── Spring Boot datasource ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=logistics_routes_dev
DB_USER=logistics_user
DB_PASSWORD=logistics_dev_pwd

# ── Redis (Docker) ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
